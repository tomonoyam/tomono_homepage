---
import Page from '../../../layouts/Page.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
import PageHeader from '../../../components/PageHeader.astro';

const articles = [
  {
    slug: 'what-is-can',
    no: '01',
    title: 'CANとは何か',
    sub: '魔法陣の通信路 — その正体',
    desc: '1985年生まれの通信プロトコルが、なぜ40年後の今も車載の主役であり続けるのか。バス型トポロジと差動信号の本質から解き明かす。',
    level: '入門',
    levelColor: 'text-green-400 border-green-800/50',
    time: '8分',
  },
  {
    slug: 'frame-structure',
    no: '02',
    title: 'フレーム構造',
    sub: '呪文の解剖 — ビット列の意味',
    desc: 'SOF、ID、RTR、DLC、データ、CRC、ACK。たった8バイトのフレームに込められた設計の妙。DataフレームからErrorフレームまで全種類を解剖。',
    level: '中級',
    levelColor: 'text-blue-400 border-blue-800/50',
    time: '12分',
  },
  {
    slug: 'arbitration-and-error',
    no: '03',
    title: '調停とエラー処理',
    sub: '仲裁の魔法 — バスを制する者',
    desc: 'CANの最大の魔法：非破壊的調停。複数の術者が同時詠唱したとき、誰が勝つのか。そしてエラーカウンタという「自己診断魔術」の仕組み。',
    level: '中級',
    levelColor: 'text-blue-400 border-blue-800/50',
    time: '14分',
  },
];

const specs = [
  { label: '規格', value: 'ISO 11898' },
  { label: '最大速度', value: '1 Mbps (Classical)' },
  { label: 'CAN FD', value: '最大 8 Mbps' },
  { label: 'トポロジ', value: 'バス型 (差動2線)' },
  { label: '最大ノード数', value: '約 30〜110' },
  { label: 'フレーム長', value: '最大 8 byte (Classical)' },
  { label: 'アドレス方式', value: 'メッセージID (11bit / 29bit)' },
  { label: '終端抵抗', value: '120 Ω × 2' },
];
---

<Page title="CAN通信 — 魔法陣の通信路 | AUTOSAR.MAGIC" description="CAN通信の全体像。バス型トポロジ・フレーム構造・調停・エラー処理をまとめた章扉。">
  <div class="max-w-6xl mx-auto px-6">
    <Breadcrumb items={[
      { label: 'HOME', href: '/' },
      { label: 'TOPICS', href: '/#topics' },
      { label: 'CAN通信' },
    ]} />

    <PageHeader
      chapter="CHAPTER 02 :: CAN BUS PROTOCOL"
      title="CAN通信 — 魔法陣の通信路"
      subtitle="1985年に召喚されたこの通信プロトコルは、いかにしてすべての車載ECUを繋ぐ共通言語となったのか。バス型差動信号から調停魔術まで。"
      meta="ISO 11898 · Classical CAN / CAN FD · Message-Based Protocol"
      accent="cyan"
    />

    <!-- Intro + Specs -->
    <section class="mb-20">
      <div class="grid md:grid-cols-3 gap-6">
        <div class="md:col-span-2 space-y-5 text-gray-300 leading-relaxed">
          <p>
            現代の自動車には、数十から百以上のECUが搭載されている。エンジン、ブレーキ、エアバッグ、メータ、カメラ — それぞれが専用のマイコンを持ち、互いに情報を交換しながら協調して動く。
          </p>
          <p>
            そのすべてを繋ぐ共通言語が <span class="text-cyan-400 font-semibold">CAN (Controller Area Network)</span> だ。1985年にBoschが発表し、ISO 11898として標準化されたこのプロトコルは、<span class="text-purple-400">シンプル・堅牢・決定論的</span>という三つの魔法を備えている。
          </p>
          <p>
            配線は2本の銅線だけ。ノードはバス型に接続され、アドレスは存在しない — データの「ID」がすべてだ。複数の術者が同時に詠唱しても、<span class="text-cyan-400">非破壊的調停</span>によって唯一の勝者が決まり、情報は失われない。
          </p>
        </div>

        <!-- Spec card -->
        <div class="border border-cyan-900/50 rounded-lg bg-[#0a0a1f]/60 p-5">
          <div class="font-mono text-[10px] text-cyan-700 tracking-widest mb-4">CAN.SPECS</div>
          <dl class="space-y-2 font-mono text-xs">
            {specs.map(s => (
              <div class="flex justify-between gap-2 border-b border-cyan-900/20 pb-1.5 last:border-none last:pb-0">
                <dt class="text-gray-500 shrink-0">{s.label}</dt>
                <dd class="text-cyan-300 text-right">{s.value}</dd>
              </div>
            ))}
          </dl>
        </div>
      </div>
    </section>

    <!-- Bus topology visual -->
    <section class="mb-24">
      <div class="flex items-center gap-4 mb-12">
        <div class="h-px flex-1 bg-gradient-to-r from-transparent to-cyan-800/50"></div>
        <span class="font-mono text-xs text-cyan-600 tracking-widest px-4">// BUS TOPOLOGY</span>
        <div class="h-px flex-1 bg-gradient-to-l from-transparent to-cyan-800/50"></div>
      </div>

      <h2 class="text-2xl md:text-3xl font-serif font-semibold text-white text-center mb-3">バス型の魔法陣</h2>
      <p class="text-gray-500 text-sm text-center mb-12 font-mono">All ECUs share a single 2-wire bus</p>

      <!-- SVG Bus Diagram -->
      <div class="border border-cyan-900/40 rounded-xl bg-[#06060f]/80 p-8 overflow-x-auto">
        <svg viewBox="0 0 800 260" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full max-w-3xl mx-auto">
          <!-- CAN_H line -->
          <line x1="80" y1="110" x2="720" y2="110" stroke="#00d4ff" stroke-width="2"/>
          <text x="30" y="114" fill="#00d4ff" font-size="11" font-family="monospace">H</text>
          <!-- CAN_L line -->
          <line x1="80" y1="150" x2="720" y2="150" stroke="#7c3aed" stroke-width="2"/>
          <text x="30" y="154" fill="#7c3aed" font-size="11" font-family="monospace">L</text>

          <!-- Termination resistors -->
          <rect x="55" y="100" width="18" height="60" rx="3" stroke="#00d4ff" stroke-width="1" fill="#0a0a1f"/>
          <text x="42" y="136" fill="#00d4ff" font-size="9" font-family="monospace" opacity="0.7">120Ω</text>
          <rect x="727" y="100" width="18" height="60" rx="3" stroke="#00d4ff" stroke-width="1" fill="#0a0a1f"/>
          <text x="714" y="136" fill="#00d4ff" font-size="9" font-family="monospace" opacity="0.7">120Ω</text>

          <!-- ECU nodes with stubs -->
          {[
            { x: 180, label: 'Engine\nECU', id: '0x100' },
            { x: 310, label: 'Brake\nECU', id: '0x200' },
            { x: 440, label: 'Meter\nECU', id: '0x300' },
            { x: 570, label: 'Airbag\nECU', id: '0x500' },
            { x: 680, label: 'GW\nECU', id: '0x7FF' },
          ].map(node => (
            <g key={node.x}>
              {/* Stub lines */}
              <line x1={node.x} y1="110" x2={node.x} y2="72" stroke="#00d4ff" stroke-width="1.5" opacity="0.6"/>
              <line x1={node.x} y1="150" x2={node.x} y2="188" stroke="#7c3aed" stroke-width="1.5" opacity="0.6"/>
              {/* ECU box */}
              <rect x={node.x - 42} y="28" width="84" height="40" rx="6" stroke="#00d4ff" stroke-width="1" fill="#0a0a1f" class="hover:fill-cyan-950/60"/>
              <text x={node.x} y="44" fill="#e2e8f0" font-size="9.5" font-family="monospace" text-anchor="middle">{node.label.split('\n')[0]}</text>
              <text x={node.x} y="57" fill="#e2e8f0" font-size="9.5" font-family="monospace" text-anchor="middle">{node.label.split('\n')[1]}</text>
              {/* ID label below */}
              <text x={node.x} y="218" fill="#00d4ff" font-size="9" font-family="monospace" text-anchor="middle" opacity="0.6">ID:{node.id}</text>
            </g>
          ))}

          <!-- Differential label -->
          <text x="400" y="248" fill="#6b7280" font-size="10" font-family="monospace" text-anchor="middle">Differential pair · 120Ω terminated · Message-based (no address)</text>
        </svg>
      </div>
    </section>

    <!-- Articles -->
    <section class="mb-24">
      <div class="flex items-center gap-4 mb-12">
        <div class="h-px flex-1 bg-gradient-to-r from-transparent to-cyan-800/50"></div>
        <span class="font-mono text-xs text-cyan-600 tracking-widest px-4">// CHAPTER ARTICLES</span>
        <div class="h-px flex-1 bg-gradient-to-l from-transparent to-cyan-800/50"></div>
      </div>

      <h2 class="text-2xl md:text-3xl font-serif font-semibold text-white text-center mb-3">この章の記事</h2>
      <p class="text-gray-500 text-sm text-center mb-12 font-mono">Entries in this chapter</p>

      <div class="grid md:grid-cols-3 gap-6">
        {articles.map(a => (
          <a href={`/topics/can/${a.slug}`} class="group relative border border-blue-900/50 rounded-xl bg-[#0a0a1f]/80 overflow-hidden hover:-translate-y-2 hover:border-blue-600/70 transition-all duration-300 hover:shadow-[0_0_30px_rgba(59,130,246,0.15)]">
            <div class="h-1 bg-gradient-to-r from-blue-500/40 to-cyan-500/40"></div>
            <div class="p-6">
              <div class="flex items-center justify-between mb-4">
                <span class={`text-[10px] font-mono px-2 py-1 rounded border ${a.levelColor}`}>{a.level}</span>
                <span class="text-gray-600 text-[11px] font-mono">{a.time}</span>
              </div>
              <div class="font-mono text-[10px] text-gray-700 mb-2">CAN · #{a.no}</div>
              <h3 class="text-white font-serif text-xl font-semibold mb-1 leading-snug group-hover:text-cyan-100 transition-colors">{a.title}</h3>
              <div class="text-cyan-500 text-xs font-mono mb-3">{a.sub}</div>
              <p class="text-gray-500 text-sm leading-relaxed line-clamp-3">{a.desc}</p>
              <div class="mt-5 pt-4 border-t border-gray-800/50 flex items-center justify-between">
                <span class="text-gray-600 text-xs font-mono">CAN.{a.no}</span>
                <span class="text-cyan-500 text-xs font-mono group-hover:translate-x-1 transition-transform">読む →</span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </section>

    <!-- Page nav -->
    <section class="mb-20 border-t border-cyan-900/30 pt-10">
      <div class="flex flex-col md:flex-row items-center justify-between gap-4 text-sm">
        <a href="/" class="font-mono text-cyan-600 hover:text-cyan-400 transition-colors">← HOME</a>
        <div class="font-mono text-xs text-gray-700 tracking-widest">CHAPTER 02 / CAN BUS</div>
        <a href={`/topics/can/${articles[0].slug}`} class="font-mono text-cyan-600 hover:text-cyan-400 transition-colors">最初の記事 →</a>
      </div>
    </section>
  </div>
</Page>
