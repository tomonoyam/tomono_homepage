                { name: 'DaVinci Developer', use: 'SWC設計・ARXML編集・SWC間接続設計' },
                { name: 'DaVinci Configurator', use: 'BSW設定・RTE生成・OSタスク設計' },
                { name: 'CANdb++ / DBC', use: 'CAN信号定義 (DBCファイル編集)' },
