                { name: 'ISOLAR-A', use: 'ARXML設計・SWC設計' },
                { name: 'ISOLAR-EVE', use: 'SIL (Software-in-the-Loop) 仮想ECUテスト' },
                { name: 'INCA', use: 'ECUキャリブレーション・測定' },
