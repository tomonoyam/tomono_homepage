---
interface Crumb {
  label: string;
  href?: string;
}
interface Props {
  items: Crumb[];
}
const { items } = Astro.props;
---
<nav class="font-mono text-xs text-cyan-700 tracking-wider flex flex-wrap items-center gap-2" aria-label="breadcrumb">
  {items.map((item, i) => (
    <>
      {i > 0 && <span class="text-cyan-900">/</span>}
      {item.href ? (
        <a href={item.href} class="hover:text-cyan-400 transition-colors">{item.label}</a>
      ) : (
        <span class="text-cyan-500">{item.label}</span>
      )}
    </>
  ))}
</nav>
