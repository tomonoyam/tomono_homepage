---
interface Props {
  chapter?: string;
  title: string;
  subtitle?: string;
  meta?: string;
  accent?: 'cyan' | 'purple' | 'amber' | 'blue' | 'green';
}
const { chapter, title, subtitle, meta, accent = 'cyan' } = Astro.props;

const accentMap = {
  cyan:   { glow: 'from-cyan-500/15 to-transparent',   text: 'text-cyan-400',   bar: 'from-cyan-400 to-blue-500' },
  purple: { glow: 'from-purple-500/15 to-transparent', text: 'text-purple-400', bar: 'from-purple-400 to-pink-500' },
  amber:  { glow: 'from-amber-500/15 to-transparent',  text: 'text-amber-400',  bar: 'from-amber-400 to-orange-500' },
  blue:   { glow: 'from-blue-500/15 to-transparent',   text: 'text-blue-400',   bar: 'from-blue-400 to-indigo-500' },
  green:  { glow: 'from-green-500/15 to-transparent',  text: 'text-green-400',  bar: 'from-green-400 to-teal-500' },
};
const a = accentMap[accent];
---
<header class="relative py-12 mb-12">
  <div class={`absolute inset-x-0 top-0 h-64 bg-gradient-to-b ${a.glow} pointer-events-none -z-10`}></div>

  {chapter && (
    <div class={`font-mono text-xs ${a.text} tracking-[0.3em] mb-4 flex items-center gap-3`}>
      <span class={`h-px w-12 bg-gradient-to-r ${a.bar}`}></span>
      <span>{chapter}</span>
    </div>
  )}

  <h1 class="text-4xl md:text-5xl lg:text-6xl font-serif font-semibold text-white leading-tight mb-4">
    {title}
  </h1>

  {subtitle && (
    <p class="text-lg md:text-xl text-gray-400 leading-relaxed font-light max-w-3xl">
      {subtitle}
    </p>
  )}

  {meta && (
    <div class="mt-6 font-mono text-xs text-gray-600 tracking-wider">{meta}</div>
  )}

  <div class={`mt-8 h-px w-full bg-gradient-to-r ${a.bar} opacity-30`}></div>
</header>
