---
const links = [
  {
    label: 'GitHub',
    handle: '@tomonoyam',
    desc: 'コードの呪文書',
    icon: `<svg viewBox="0 0 24 24" fill="currentColor" class="w-6 h-6"><path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/></svg>`,
    href: 'https://github.com/tomonoyam',
    color: 'border-gray-700/50 hover:border-gray-500',
    textColor: 'text-gray-400 hover:text-gray-200',
    iconColor: 'text-gray-400',
  },
  {
    label: 'X (Twitter)',
    handle: '@tomono_magic',
    desc: '思考の断片・呟き',
    icon: `<svg viewBox="0 0 24 24" fill="currentColor" class="w-6 h-6"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.746l7.73-8.835L1.254 2.25H8.08l4.259 5.63 5.905-5.63zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>`,
    href: 'https://x.com/tomono_magic',
    color: 'border-sky-800/50 hover:border-sky-500',
    textColor: 'text-sky-400 hover:text-sky-300',
    iconColor: 'text-sky-400',
  },
  {
    label: 'Email',
    handle: 'tomono@example.com',
    desc: '魔法の伝達手段',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="w-6 h-6"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>`,
    href: 'mailto:tomono@example.com',
    color: 'border-purple-800/50 hover:border-purple-500',
    textColor: 'text-purple-400 hover:text-purple-300',
    iconColor: 'text-purple-400',
  },
];
---

<section id="contact" class="relative py-32 px-6">
  <!-- Scan line effect -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none opacity-5">
    <div class="w-full h-px bg-gradient-to-r from-transparent via-cyan-400 to-transparent animate-scan"></div>
  </div>

  <div class="max-w-4xl mx-auto">
    <!-- Section label -->
    <div class="flex items-center gap-4 mb-6">
      <div class="h-px flex-1 bg-gradient-to-r from-transparent to-cyan-800/50"></div>
      <span class="font-mono text-xs text-cyan-600 tracking-widest px-4">// CONTACT</span>
      <div class="h-px flex-1 bg-gradient-to-l from-transparent to-cyan-800/50"></div>
    </div>

    <div class="text-center mb-16">
      <h2 class="text-3xl md:text-4xl font-serif font-semibold text-white mb-4">
        通信を確立する
      </h2>
      <p class="text-gray-500 text-sm font-mono">Establish connection :: SELECT CHANNEL</p>
    </div>

    <!-- Terminal-style container -->
    <div class="border border-cyan-900/40 rounded-xl bg-[#0a0a1f]/80 overflow-hidden">
      <!-- Terminal header -->
      <div class="flex items-center gap-2 px-4 py-3 border-b border-cyan-900/40 bg-[#06060f]/80">
        <div class="w-3 h-3 rounded-full bg-red-500/60"></div>
        <div class="w-3 h-3 rounded-full bg-yellow-500/60"></div>
        <div class="w-3 h-3 rounded-full bg-green-500/60"></div>
        <span class="ml-3 font-mono text-xs text-gray-600">contact.sh — CHANNEL SELECTOR</span>
      </div>

      <!-- Terminal content -->
      <div class="p-6 md:p-8">
        <div class="font-mono text-xs text-gray-600 mb-6">
          <span class="text-green-500">$</span> ./contact.sh --list-channels
        </div>

        <div class="grid md:grid-cols-3 gap-4">
          {links.map(link => (
            <a
              href={link.href}
              target="_blank"
              rel="noopener noreferrer"
              class={`group relative border ${link.color} rounded-lg p-5 bg-transparent transition-all duration-300 hover:-translate-y-1 hover:shadow-lg`}
            >
              <div class={`${link.iconColor} mb-3 transition-transform group-hover:scale-110`} set:html={link.icon} />
              <div class="font-mono text-xs text-gray-600 mb-1">{link.label}</div>
              <div class={`font-mono text-sm ${link.textColor} transition-colors mb-2`}>{link.handle}</div>
              <div class="text-gray-600 text-xs">{link.desc}</div>

              <!-- Arrow -->
              <div class="absolute top-4 right-4 text-gray-700 group-hover:text-gray-400 transition-colors text-xs font-mono">↗</div>
            </a>
          ))}
        </div>

        <div class="mt-6 font-mono text-xs text-gray-700">
          <span class="text-green-500">$</span>
          <span class="text-gray-600"> connection ready. awaiting transmission</span>
          <span class="animate-pulse text-cyan-400">_</span>
        </div>
      </div>
    </div>
  </div>
</section>
